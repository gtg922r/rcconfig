#!/usr/bin/env bash
# One-time vault initialization.
set -euo pipefail

CIPHER_DIR="$HOME/.config/credentialVault/cipher"
MNT_DIR="$HOME/.credentialVault"
LINKS_CONF="$HOME/.config/credentialVault/links.conf"

if [ -f "$CIPHER_DIR/gocryptfs.conf" ]; then
    echo "❌ Vault already initialized. Nothing to do."
    exit 1
fi

mkdir -p "$CIPHER_DIR" "$MNT_DIR"

echo "=== Initializing encrypted vault ==="
echo "You'll be prompted to set a password. Remember it!"
echo ""
gocryptfs -init "$CIPHER_DIR"

echo ""
echo "=== Mounting vault ==="
gocryptfs "$CIPHER_DIR" "$MNT_DIR"

# Create .env template
cat > "$MNT_DIR/.env" <<'EOF'
# Credential vault environment variables
# Sourced automatically when the vault is open.
# Add secrets/env vars needed by apps whose credentials live in the vault.
EOF
chmod 600 "$MNT_DIR/.env"

# Create links.conf if it doesn't exist
if [ ! -f "$LINKS_CONF" ]; then
    cat > "$LINKS_CONF" <<'EOF'
# Credential vault symlink mappings
# Format: <dir-inside-vault>  <target-symlink-path>
# ~ is expanded to $HOME. Lines starting with # are ignored.
EOF
fi

# Create dirs and activate symlinks from links.conf
if [ -f "$LINKS_CONF" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        [[ -z "${line// /}" ]] && continue
        read -r vault_dir target <<< "$line"
        target="${target/#\~/$HOME}"
        mkdir -p "$MNT_DIR/$vault_dir" "$(dirname "$target")"
        [ -d "$target" ] && [ ! -L "$target" ] && rm -rf "$target"
        ln -sfn "$MNT_DIR/$vault_dir" "$target"
    done < "$LINKS_CONF"
fi

echo ""
echo "✅ Vault initialized and mounted."
echo "   Cipher:    $CIPHER_DIR"
echo "   Mount:     $MNT_DIR"
echo "   Links:     $LINKS_CONF"
echo "   Env file:  $MNT_DIR/.env"
echo ""
echo "Commands:"
echo "   vault-open    — mount the vault"
echo "   vault-close   — unmount the vault (locks credentials)"
echo "   vault-status  — check vault state"
